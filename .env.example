APP_ENV=development
APP_SECRET_KEY=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

DATABASE_URL=sqlite+aiosqlite:///./data/qqbot.db
REDIS_URL=

ONEBOT_CONNECTION_MODE=reverse_ws
ONEBOT_REVERSE_WS_PATH=/onebot/ws
ONEBOT_ACCESS_TOKEN=
BOT_QQ=
BOT_NICKNAMES=bot,助手
ADMIN_QQ_IDS=
COMMAND_PREFIX=/
ALLOWED_GROUPS=
DEFAULT_GROUP_ENABLED=true
DEFAULT_REPLY_MODE=mention_only

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=30

RATE_LIMIT_PER_USER_PER_MINUTE=12
RATE_LIMIT_PER_GROUP_PER_MINUTE=60
