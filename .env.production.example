APP_ENV=production
APP_SECRET_KEY=change-this-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

POSTGRES_DB=qqbot
POSTGRES_USER=qqbot
POSTGRES_PASSWORD=change-this-postgres-password

DATABASE_URL=postgresql+asyncpg://qqbot:change-this-postgres-password@postgres:5432/qqbot
REDIS_URL=redis://redis:6379/0
KNOWLEDGE_FILE_DIR=./data/knowledge_files

ONEBOT_CONNECTION_MODE=reverse_ws
ONEBOT_REVERSE_WS_PATH=/onebot/ws
ONEBOT_REVERSE_WS_URL=ws://bot-app:8000/onebot/ws
ONEBOT_ACCESS_TOKEN=change-this-onebot-token
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest
WEB_ADMIN_IMAGE=ghcr.io/ky-wyc/yh-hh-web-admin:latest
NAPCAT_UID=1000
NAPCAT_GID=1000
LAGRANGE_SIGN_SERVER_URL=
LAGRANGE_SIGN_PROXY_URL=
LAGRANGE_MUSIC_SIGN_SERVER_URL=

BOT_QQ=
BOT_NICKNAMES=bot,助手
ADMIN_QQ_IDS=
COMMAND_PREFIX=/
ALLOWED_GROUPS=
DEFAULT_GROUP_ENABLED=true
DEFAULT_REPLY_MODE=mention_only
PRIVATE_CHAT_ENABLED=false
PRIVATE_CHAT_WHITELIST=

LLM_PROVIDER=openai_compatible
LLM_ENDPOINT_TYPE=chat_completions
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=30

EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=64
EMBEDDING_TIMEOUT_SECONDS=30

IMAGE_PROVIDER=openai_compatible
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_API_KEY=
IMAGE_MODEL=image2
IMAGE_SIZE=1024x1024
IMAGE_TIMEOUT_SECONDS=120

RATE_LIMIT_PER_USER_PER_MINUTE=12
RATE_LIMIT_PER_GROUP_PER_MINUTE=60
MEMORY_SUMMARY_BY_COUNT_ENABLED=false
MEMORY_SUMMARY_MESSAGE_THRESHOLD=100
